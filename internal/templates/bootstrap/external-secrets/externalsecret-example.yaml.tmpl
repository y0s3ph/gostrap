# Example ExternalSecret — references the ClusterSecretStore to sync
# a secret from your external provider into a Kubernetes Secret.
#
# Adapt the remoteRef keys to match your provider's secret paths.
#
# For full docs: https://external-secrets.io/latest/guides/introduction/
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: example-secret
  namespace: default
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: cluster-secret-store
    kind: ClusterSecretStore
  target:
    name: example-secret
    creationPolicy: Owner
  data:
    - secretKey: username
      remoteRef:
        key: my-app/credentials
        property: username
    - secretKey: password
      remoteRef:
        key: my-app/credentials
        property: password
