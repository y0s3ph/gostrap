# Example Kubernetes Secret — encrypt this file with SOPS before committing.
#
# Usage:
#   1. Fill in your actual secret values below.
#   2. Encrypt in-place:  sops --encrypt --in-place secret-example.yaml
#   3. Commit the encrypted file to Git.
#   4. To edit later:     sops secret-example.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: example-secret
  namespace: default
type: Opaque
stringData:
  DB_HOST: localhost
  DB_USER: myapp
  DB_PASSWORD: CHANGE-ME
