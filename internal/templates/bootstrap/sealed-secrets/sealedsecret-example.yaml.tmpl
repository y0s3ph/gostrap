# Example SealedSecret — encrypt with kubeseal before committing.
#
# 1. Create a regular Secret:
#    kubectl create secret generic my-secret \
#      --from-literal=username=admin \
#      --from-literal=password=changeme \
#      --dry-run=client -o yaml > my-secret.yaml
#
# 2. Seal it (uses the cluster's public cert):
#    kubeseal --format yaml < my-secret.yaml > my-sealedsecret.yaml
#
# 3. Commit the SealedSecret (never the plain Secret).
#
# To seal offline (without cluster access), use the exported cert:
#    kubeseal --cert bootstrap/sealed-secrets/pub-cert.pem \
#      --format yaml < my-secret.yaml > my-sealedsecret.yaml
---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: example-secret
  namespace: default
spec:
  encryptedData:
    username: "<sealed-value>"
    password: "<sealed-value>"
  template:
    metadata:
      name: example-secret
      namespace: default
    type: Opaque
